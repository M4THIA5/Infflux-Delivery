// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  DELIVER
  CUSTOMER
}

enum IncidentType {
  ROUTIER
  CASSE
  PERTE
  PAUSE_CAFE
  DOUANE
}

model User {
  id               String   @id @default(cuid())
  role             UserRole
  name             String
  email            String   @unique
  password         String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  customerCourses  Course[] @relation("CustomerCourses")
  deliveredCourses Course[] @relation("DeliveredCourses")
  incidents        Incident[]
}

model Entrepot {
  id        String   @id @default(cuid())
  addresse  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses   Course[]
}

model Course {
  id               String    @id @default(cuid())
  dateHeureDebut   DateTime
  dateHeureArrivee DateTime?
  prix             Decimal   @db.Decimal(10, 2)
  adresseLivraison String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  customerId       String
  delivererId      String?
  entrepotId       String

  customer         User      @relation("CustomerCourses", fields: [customerId], references: [id])
  deliverer        User?     @relation("DeliveredCourses", fields: [delivererId], references: [id])
  entrepot         Entrepot  @relation(fields: [entrepotId], references: [id])
  incidents        Incident[]
}

model Incident {
  id          String       @id @default(cuid())
  type        IncidentType
  commentaire String
  createdAt   DateTime     @default(now())

  courseId    String
  userId      String

  course      Course       @relation(fields: [courseId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
}
